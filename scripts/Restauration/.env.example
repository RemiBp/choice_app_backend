# Configuration des APIs
OPENAI_API_KEY=sk-votre-clé-openai-uniquement-en-fallback

# Configuration Hugging Face (PRIORITAIRE)
HF_API_TOKEN=hf_votre-token-huggingface
HF_SPACE_NAME=votre-username/mixtral-space
USE_HUGGING_FACE=true
AUTO_SHUTDOWN=true

# Configuration OCR (Optionnel pour la reconnaissance d'images)
GOOGLE_VISION_API_KEY=votre-clé-google-vision-optionnelle
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe

# Configuration MongoDB (si différente de la valeur par défaut)
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority